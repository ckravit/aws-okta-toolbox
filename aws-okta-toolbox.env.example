# aws-okta-toolbox.env
# Source it before using any toolbox commands:
#   source /path/to/aws-okta-toolbox.env
#
# Or add that line to ~/.zshrc / ~/.bashrc to load it automatically on
# every new terminal session. If you make changes to this file, re-source it.

# ── Aliases ───────────────────────────────────────────────────────────────────
# Allows calling scripts without the .sh extension.
alias okta-auth='okta-auth.sh'
alias awstunnel='awstunnel.sh'
alias awsdo='awsdo.sh'

# ── Okta configuration ────────────────────────────────────────────────────────
# Required. Provided by your Okta/AWS admin.
export OKTA_ORG_DOMAIN=""           # e.g. mycompany.okta.com
export OKTA_OIDC_CLIENT_ID=""       # e.g. 0oa1b2c3d4e5f6g7h8i9

# ── AWS configuration ─────────────────────────────────────────────────────────
export AWS_DEFAULT_REGION="us-west-2"

# ── Instance IDs and connection targets ───────────────────────────────────────
# Add your own below. Use descriptive names so commands are readable.
# Example usage after sourcing:
#   awstunnel.sh jupyter $JUPYTER_INSTANCE
#   awstunnel.sh db $PROD_DB_INSTANCE $PROD_DB_HOST 5432

# Jupyter
export JUPYTER_INSTANCE=""          # i-0abc1234567890def

# Databases
export PROD_DB_INSTANCE=""          # i-0abc1234567890def (bastion/EC2 instance)
export PROD_DB_HOST=""              # e.g. prod.cluster.us-west-2.rds.amazonaws.com
export PROD_DB_PORT="5432"          # 5432=postgres, 3306=mysql

# Add more as needed:
# export STAGING_DB_INSTANCE=""
# export STAGING_DB_HOST=""
